{
  "model": "opus",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "command -v rtk >/dev/null && rtk hook claude || exit 0"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/env-read-guard.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/env-read-guard.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/orch-read-cap.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "^(Task|Agent)$",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/orch-usage-guard.sh",
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "(AskUserQuestion|mcp__.*__AskUserQuestion)",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/skills/gstack/hosts/claude/hooks/question-preference-hook",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "^(Task|Agent|SendMessage)$",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/orch-return-cap.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "(AskUserQuestion|mcp__.*__AskUserQuestion)",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/skills/gstack/hosts/claude/hooks/question-log-hook",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "(AskUserQuestion|mcp__.*__AskUserQuestion)",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/skills/gstack/hosts/claude/hooks/auq-error-fallback-hook",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "s=$(ls -t $HOME/.claude/plugins/cache/ponytail/ponytail/*/hooks/ponytail-statusline.sh 2>/dev/null | head -1); [ -n \"$s\" ] && bash \"$s\""
  },
  "enabledPlugins": {
    "caveman@caveman": true,
    "ponytail@ponytail": true,
    "serena@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": false,
    "ralph-skills@ralph-marketplace": false,
    "hookify@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": false,
    "commit-commands@claude-plugins-official": true,
    "compound-engineering@compound-engineering-plugin": false,
    "context7@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": false,
    "pyright-lsp@claude-plugins-official": false,
    "playwright@claude-plugins-official": false,
    "github@claude-plugins-official": false,
    "security-guidance@claude-plugins-official": false,
    "agent-sdk-dev@claude-plugins-official": false,
    "plugin-dev@claude-plugins-official": false,
    "feature-dev@claude-plugins-official": false,
    "frontend-design@claude-plugins-official": false,
    "claude-code-setup@claude-plugins-official": false,
    "claude-md-management@claude-plugins-official": false,
    "code-simplifier@claude-plugins-official": false,
    "skill-creator@claude-plugins-official": false,
    "explanatory-output-style@claude-plugins-official": false,
    "learning-output-style@claude-plugins-official": false,
    "figma@claude-plugins-official": false,
    "telegram@claude-plugins-official": false,
    "atlassian@claude-plugins-official": false,
    "playground@claude-plugins-official": false,
    "sourcegraph@claude-plugins-official": false,
    "vercel@claude-plugins-official": false,
    "supabase@claude-plugins-official": false
  },
  "extraKnownMarketplaces": {
    "compound-engineering-plugin": {
      "source": {
        "source": "github",
        "repo": "EveryInc/compound-engineering-plugin"
      }
    },
    "ralph-marketplace": {
      "source": {
        "source": "github",
        "repo": "snarktank/ralph"
      }
    },
    "caveman": {
      "source": {
        "source": "github",
        "repo": "JuliusBrussee/caveman"
      }
    },
    "ponytail": {
      "source": {
        "source": "github",
        "repo": "DietrichGebert/ponytail"
      }
    }
  },
  "outputStyle": "default",
  "skipWorkflowUsageWarning": true,
  "theme": "dark"
}
